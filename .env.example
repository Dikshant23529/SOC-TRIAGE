# Application
SECRET_KEY=generate-with-openssl-rand-hex-32
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Database (default: SQLite in ./data)
DATABASE_URL=sqlite+aiosqlite:///./data/triage.db
# Postgres example (use docker compose --profile postgres):
# DATABASE_URL=postgresql+asyncpg://triage:triage@postgres:5432/triage

# Docker Hub (CI/CD — set as GitHub secrets)
DOCKERHUB_USERNAME=yourusername
DOCKERHUB_TOKEN=your-docker-hub-access-token
DOCKER_IMAGE=yourusername/soc-alert-triage
